{
  "name": "kiro-ai-provider",
  "version": "0.1.1",
  "description": "Kiro (AWS) provider for Vercel AI SDK",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@ai-sdk/provider": ">=3.0.0"
  },
  "dependencies": {
    "@smithy/eventstream-codec": "^4.0.3",
    "@smithy/types": "^4.3.1"
  },
  "devDependencies": {
    "@ai-sdk/provider": "^3.0.8",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "bun-types": "^1.3.0"
  },
  "keywords": ["kiro", "aws", "ai-sdk", "vercel-ai", "language-model", "provider"],
  "repository": {
    "type": "git",
    "url": "https://github.com/NachoFLizaur/kiro-ai-provider"
  },
  "author": "Nacho F. Lizaur"
}
